# ==============================================================================
# GLOBAL INFRASTRUCTURE STATE
# ==============================================================================

# WHAT THIS DOES: Defines the isolated bridge network for all AI services.
# WHY THIS DEFAULT: Ensures services (Gateway, Proxy, Runners) can communicate
# securely via internal DNS aliases (e.g., 'active-proxy') without exposing ports
# directly to the host OS unnecessarily.
NETWORK_NAME=openclaw-network

# WHAT THIS DOES: Sets the absolute path to the framework repository.
# WHY THIS DEFAULT: The placeholder AUTO_PWD is automatically replaced by the
# Python bootstrap script. This absolute path ensures that nested Docker Compose
# files resolve volume mounts correctly regardless of which directory the Make
# command is executed from.
OPENCLAW_ROOT=change_me_to_AUTO_PWD

# ==============================================================================
# GLOBAL STORAGE CONFIGURATION (CRITICAL)
# ==============================================================================

# WHAT THIS DOES: Defines where heavy, persistent data is stored.
# WHY THIS DEFAULT: On a minimal hardware setup (e.g., 16GB RAM laptop), the
# internal SSD is often small. Local LLM weights (GGUF files), PostgreSQL vector
# embeddings, and LiteLLM telemetry logs will rapidly consume hundreds of
# gigabytes. Leaving this on your root drive will lead to disk exhaustion and
# OS crashes. You MUST acquire a 1-2TB external SSD (e.g., Samsung T7) for this
# path.
# UPGRADE PATH: On a dedicated cloud VPS, map this path to an attached
# high-IOPS block storage volume (e.g., AWS EBS io2) to maximize semantic
# search speed.
# Example macOS: /Volumes/YOUR_EXTERNAL_DRIVE_NAME/metaclaw
EXTERNAL_DRIVE_PATH=${OPENCLAW_ROOT}/external/metaclaw
