# ==============================================================================
# POSTGRES-DB LOCAL ENVIRONMENT VARIABLES
# Copy this file to .env and populate with secure values.
# ==============================================================================

# WHAT THIS DOES: Specifies the exact Docker image for the database, including the pgvector extension.
# WHY THIS DEFAULT: The 'pg16' tag automatically pulls the latest pgvector release compiled against PostgreSQL 16 for your host architecture (macOS ARM64, Windows AMD64 via WSL2, or Linux). This ensures fast, native execution without emulation overhead.
# UPGRADE PATH: If moving to a managed cloud database (like AWS RDS), you can drop this container entirely, provided the cloud instance supports the pgvector extension.
PGVECTOR_IMAGE=pgvector/pgvector:pg16

# WHAT THIS DOES: Superuser credentials. Do NOT use these in application code.
# WHY THIS DEFAULT: Explicit isolation. The root user is only used by the `init-roles.sh` script during the very first boot to provision the lower-privilege application roles below.
POSTGRES_SUPER_USER=postgres
POSTGRES_SUPER_PASSWORD=change_me_to_AUTO_PASSWORD

# WHAT THIS DOES: Application-specific credentials for the proxy layer and gateway layer.
# WHY THIS DEFAULT: Principle of least privilege. OpenClaw cannot drop LiteLLM's tables, and LiteLLM cannot read OpenClaw's internal memory buffers. If one service is compromised, the blast radius is contained.
LITELLM_DB_USER=litellm_app
LITELLM_DB_PASSWORD=change_me_to_AUTO_PASSWORD
OPENCLAW_DB_USER=openclaw_app
OPENCLAW_DB_PASSWORD=change_me_to_AUTO_PASSWORD

# ==============================================================================
# ARCHITECTURAL SHIFT: SECRET DECOUPLING (THE MEMORY INTERFACE)
# ==============================================================================
# WHAT THIS DOES: The database component constructs the connection strings dynamically using the network alias 'active-memory'. Downstream consumers only read these generic strings.
# WHY THIS DEFAULT: If you eventually swap PostgreSQL for a different compatible memory backend, you only update the connection string here. The downstream gateway and proxy containers require zero configuration changes.

ACTIVE_MEMORY_URL_PROXY=postgresql://${LITELLM_DB_USER}:${LITELLM_DB_PASSWORD}@active-memory:5432/litellm_db
ACTIVE_MEMORY_URL_GATEWAY=postgresql://${OPENCLAW_DB_USER}:${OPENCLAW_DB_PASSWORD}@active-memory:5432/openclaw_db
