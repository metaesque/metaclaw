# ==============================================================================
# BROWSER USE API LOCAL ENVIRONMENT VARIABLES
# ==============================================================================

# WHAT THIS DOES: Sets the Browser Use REST API image version.
# WHY THIS DEFAULT: The 'reqeique/browser-use-api' repository does not currently
# publish semantic version releases (e.g., v1.0.0). We are making an explicit
# exception to the immutable infrastructure rule by using 'latest' until upstream
# tagging practices improve.
BROWSERUSE_VERSION=latest

# WHAT THIS DOES: Binds the API port to the host for local interface mapping.
# WHY THIS DEFAULT: Port 8080 matches the container's native listening port.
# UPGRADE PATH: If deploying to a cloud VPC, consider placing this behind an
# SSL-terminating reverse proxy rather than exposing 8080 directly.
BROWSERUSE_PORT=8080
