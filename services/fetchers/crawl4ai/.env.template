# ==============================================================================
# CRAWL4AI LOCAL ENVIRONMENT VARIABLES
# ==============================================================================

# WHAT THIS DOES: Sets the Crawl4AI API image version.
# WHY THIS DEFAULT: The 'basic-amd64' tag ensures the container only pulls the dependencies
# necessary for web crawling and markdown extraction. We explicitly use the amd64 tag
# to prevent 'exec format errors' on Ubuntu Linux nodes. Apple Silicon Macs (Tier 0)
# will seamlessly execute this AMD64 image via Rosetta 2 under OrbStack.
CRAWL4AI_VERSION=basic-amd64

# WHAT THIS DOES: Binds the API port to the host for local interface mapping.
# WHY THIS DEFAULT: Port 11235 is the native FastAPI port established by Crawl4AI.
CRAWL4AI_PORT=11235

# WHAT THIS DOES: Authenticates incoming requests to this crawler instance.
# WHY THIS DEFAULT: Required to prevent unauthorized network access to the API if
# deployed across a distributed cluster or exposed to Tailscale.
CRAWL4AI_API_TOKEN=change_me_to_a_secure_random_string

# WHAT THIS DOES: Sets the maximum concurrent browser tabs the engine will manage.
# WHY THIS DEFAULT: Throttles headless browser processes to prevent RAM exhaustion.
# A limit of 5 is highly safe for a 16GB node while still maintaining speed.
MAX_CONCURRENT_TASKS=5
