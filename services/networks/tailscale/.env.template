# ==============================================================================
# TAILSCALE OVERLAY NETWORK CONFIGURATION
# ==============================================================================

# WHAT THIS DOES: Authenticates this node to your secure Tailscale mesh network.
# WHY THIS DEFAULT: Without this, nodes in different physical locations (or behind
# CGNAT like Starlink) cannot communicate securely.
# HOW TO GET IT: Go to https://login.tailscale.com/admin/settings/keys
# IMPORTANT: You must generate a "Reusable" auth key so you can use the exact
# same key for all nodes in your MetaClaw cluster.
TAILSCALE_AUTHKEY=change_me_to_
