# ==============================================================================
# SEARXNG LOCAL ENVIRONMENT VARIABLES
# ==============================================================================

# WHAT THIS DOES: Sets the SearXNG Docker image version.
# WHY THIS DEFAULT: The searxng/searxng repository predominantly uses rolling
# releases via the 'latest' tag, alongside rolling date hashes. To balance
# stability with continuous security updates for search engine scrapers, 'latest'
# is the community standard.
SEARXNG_VERSION=latest

# WHAT THIS DOES: Binds the API port to the host for local interface mapping.
# WHY THIS DEFAULT: Port 9003 ensures no collision with primary web servers or proxies.
SEARXNG_PORT=9003

# WHAT THIS DOES: A cryptographic secret used by SearXNG to secure user sessions.
# WHY THIS DEFAULT: Required to start the SearXNG application cleanly.
SEARXNG_SECRET_KEY=change_me_to_a_secure_random_string
