# ==============================================================================
# OLLAMA LOCAL ENVIRONMENT VARIABLES
# ==============================================================================

# WHAT THIS DOES: Sets the Ollama release version to download.
# IMPORTANT: For bare-metal deployments, leave this blank to automatically fetch
# the latest stable GitHub release. Do NOT use Docker tags like 'rocm' here.
OLLAMA_VERSION=

# WHAT THIS DOES: The port Ollama listens on for incoming inference requests.
OLLAMA_PORT=11434

# WHAT THIS DOES: Binds the Ollama API to all network interfaces.
# WHY THIS DEFAULT: 0.0.0.0 is required so that the Tailscale interface can route
# traffic from the Control Node to this Compute Node over the WAN.
OLLAMA_HOST=change_me_to_HOST[0.0.0.0]

# WHAT THIS DOES: Forces the AMD ROCm driver to compile for a specific graphics architecture.
# WHY THIS DEFAULT: Modern APUs (like the Ryzen AI Max+ 395) utilize RDNA3.5 (gfx1151).
# Setting this to 11.0.0 forces compatibility with standard RDNA3.
HSA_OVERRIDE_GFX_VERSION=change_me_to_GFX_VERSION[11.0.0]

# WHAT THIS DOES: Injected dynamically by orchestrate.py to inform the local Makefile which models to auto-pull on boot.
OLLAMA_TARGET_MODELS=change_me_to_MODELS[]
