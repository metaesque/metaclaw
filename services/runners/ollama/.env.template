# ==============================================================================
# OLLAMA LOCAL ENVIRONMENT VARIABLES
# ==============================================================================

# WHAT THIS DOES: Sets the Ollama image version.
# WHY THIS DEFAULT: 'rocm' ensures the container pulls the AMD GPU compatible layers.
OLLAMA_VERSION=rocm

# WHAT THIS DOES: The port Ollama listens on for incoming inference requests.
OLLAMA_PORT=11434

# WHAT THIS DOES: Binds the Ollama API to all network interfaces.
# WHY THIS DEFAULT: 0.0.0.0 is required so that the Tailscale interface can route
# traffic from the Control Node to this Compute Node over the WAN. If left as the
# default 127.0.0.1, Ollama will drop all remote requests.
OLLAMA_HOST=change_me_to_HOST[0.0.0.0]

# WHAT THIS DOES: Forces the AMD ROCm driver to compile for a specific graphics architecture.
# WHY THIS DEFAULT: Modern APUs (like the Ryzen AI Max+ 395 / Strix Halo) utilize RDNA3.5 (gfx1151).
# If the native ROCm libraries fail to auto-detect this cutting-edge silicon, setting this
# to 11.0.0 forces compatibility with standard RDNA3, preventing silent fallback to CPU inference.
HSA_OVERRIDE_GFX_VERSION=change_me_to_GFX_VERSION[11.0.0]
