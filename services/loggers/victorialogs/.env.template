# ==============================================================================
# VICTORIALOGS LOCAL ENVIRONMENT VARIABLES
# ==============================================================================

# WHAT THIS DOES: Pins the VictoriaLogs engine to a stable release.
# WHY THIS DEFAULT: VictoriaLogs is under active development. Pinning to v1.45.0
# ensures our REST ingestion endpoints remain stable and prevents breaking schema changes.
VICTORIALOGS_VERSION=v1.45.0
VICTORIALOGS_PORT=9428

# WHAT THIS DOES: Defines the retention policy for agent logs.
# WHY THIS DEFAULT: Logs expand exponentially during intensive agent loops. Automatically
# trimming logs older than 14 days guarantees that your external SSD will not fill up
# silently, while maintaining a large enough window for debugging and behavior auditing.
VICTORIALOGS_RETENTION=14d
