# It analyzes every prompt and routes trivial questions (like "What is 2+2?") to
# a cheap/free API tier, while saving your expensive API keys for complex coding tasks.

GEMINI_API_KEY=change_me_to_GEMINI_API_KEY[AIzaSyCOUJTuUzpX5TWk7XhoZJK5dyY1sgHIXZE]

LITELLM_PORT=4000
LITELLM_VERSION=v1.82.3-stable.patch.2
LITELLM_LOG=INFO

# Master key MUST start with 'sk-' to pass Virtual Key validation
# ARCHITECTURAL SHIFT: This is the globally exposed interface key consumed by the Gateway
