# ==============================================================================
# PROXY ROUTING TIERS (COST MANAGEMENT)
# ==============================================================================
# WHAT THIS DOES: OpenClaw uses a "Predictive Router" to save you money.
# It analyzes every prompt and routes trivial questions (like "What is 2+2?") to
# a cheap/free API tier, while saving your expensive API keys for complex coding tasks.
#
# WHY THESE DEFAULTS: We default to Google Gemini because their free tier is extremely
# generous for personal use. You can get free keys from Google AI Studio.
#
# UPGRADE PATH: If you want to use OpenAI or Anthropic later, you simply change
# the routing mappings in `config.yaml`.

# Uses project 'Default Gemini Project'
TIER_0_APIKEY=change_me_to_GEMINI_FREE_TIER_API_KEY

# Uses project 'meta-openclaw'
TIER_1_APIKEY=change_me_to_GEMINI_PAID_TIER_API_KEY

GEMINI_API_KEY_SIMPLE=${TIER_0_APIKEY}
GEMINI_API_KEY_MEDIUM=${TIER_1_APIKEY}
GEMINI_API_KEY_COMPLEX=${TIER_1_APIKEY}
GEMINI_API_KEY_REASONING=${TIER_1_APIKEY}
GEMINI_API_KEY_EMBEDDING=${TIER_1_APIKEY}

LITELLM_PORT=4000
LITELLM_VERSION=v1.82.3-stable.patch.2
LITELLM_LOG=INFO

# Master key MUST start with 'sk-' to pass Virtual Key validation
# ARCHITECTURAL SHIFT: This is the globally exposed interface key consumed by the Gateway
ACTIVE_PROXY_KEY=change_me_to_AUTO_PASSWORD_SK

# Internal mapping for Litellm legacy logic
LITELLM_MASTER_KEY=${ACTIVE_PROXY_KEY}

# ==============================================================================
# DYNAMIC INFRASTRUCTURE ESCALATION TIERS (TIER 1 VS TIER 2)
# ==============================================================================
# WHAT THIS DOES: Maps the primary reasoning and text orchestration engines.
COMPLEX_MODEL_ID=change_me_to_MODEL_IDENTIFIER[gemini/gemini-3.1-pro-preview]
COMPLEX_MODEL_API_BASE=change_me_to_ENDPOINT_BASE_URL[https://gateway.ai.google]
COMPLEX_MODEL_API_KEY=${GEMINI_API_KEY_COMPLEX}

# --- Execution Overrides ---
USE_MONKEY_PATCH=false

# Directs the 'json_logs' success callback to output to our mapped persistent volume
JSON_LOGS_DIR=/app/logs

# Workaround for semantic_router/encoders/litellm.py implicit key binding bug
GEMINI_API_KEY=${GEMINI_API_KEY_EMBEDDING}
