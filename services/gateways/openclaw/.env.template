# The version of openclaw to use.
#  - [https://github.com/openclaw/openclaw/releases](https://github.com/openclaw/openclaw/releases)
#  - Look for the 'OpenClaw 2026.<M>.<D>' release.
#  - Note: Docker image tags omit the 'v' prefix found on Git tags.
#  - ex: Git tag 'v2026.4.5' translates to image tag '2026.4.5'
#  - do NOT use 'latest' as this violates the principle of immutable
#    infrastructure (for critical infrastructure like OpenClaw).
OPENCLAW_VERSION=change_me_to_OPENCLAW_IMAGE_TAG[2026.6.8]

# The port that the openclaw gateway binds to on the host computer
OPENCLAW_PORT=18789

# ==============================================================================
# CONTAINER ENVIRONMENT ABSTRACTION
# ==============================================================================
# WHAT THIS DOES: Parameterizes the internal Docker container user and home directory.
# WHY THIS DEFAULT: We explicitly run the container as uid 1000 (standard host user)
# instead of root. This natively satisfies the OpenClaw Plugin Security validation
# (suspicious ownership) since the mounted workspace files will identically match
# the running process uid.
# UPGRADE PATH: Docker-out-of-Docker (DooD) is preserved via group_add in docker-compose.yml.
OPENCLAW_USER=1000
OPENCLAW_INTERNAL_HOME=/home/node

# ==============================================================================
# EXTERNAL WORKSPACE BINDING
# ==============================================================================
# WHAT THIS DOES:
#   Mounts an absolute path from your host OS directly into the container as the
#   agent's secure workspace jail.
# WHY THIS IS EXTERNAL:
#   The workspace contains your highly personal data, proprietary agent code, and
#   conversation histories. By placing it OUTSIDE the MetaClaw git repository,
#   it is fully insulated from MetaClaw's destructive 'clean-state' operations.
#   Docker natively mounts this absolute path, requiring zero sync scripts.
OPENCLAW_WORKSPACE=change_me_to_EXTERNAL_WORKSPACE_PATH[../workspace]

# ==============================================================================
# PIPELINE ROUTING CONFIGURATION
# ==============================================================================

# 1. SEMANTIC MATCHING (Prompt -> Agent)
# Disables default LLM tool-calling for agent selection and utilizes ClawRouter.
OPENCLAW_ENABLE_CLAWROUTER=true
# The LiteLLM endpoint used by ClawRouter to generate vectors for agent skill signatures.
OPENCLAW_ROUTER_EMBEDDING_MODEL=litellm/prompt-embedding-model

# 2. PREDICTIVE SCORING (Prompt -> Model via LLM-as-a-Judge)
# The local model used by the `before_model_resolve` hook to assess complexity.
# This should point directly to your fast, quantized local runner.
OPENCLAW_JUDGE_MODEL=change_me_to_a_local_judge_model[ollama/gemma4:e4b]

# 3. CONTENT CONSTRAINTS (Cost/Security Overrides)
# Maximum allowable tokens in a context window before forcing a specific model fallback.
OPENCLAW_MAX_CONTEXT_TOKENS=32000

# ==============================================================================
# DEVELOPER & DIAGNOSTIC FEATURES
# ==============================================================================

# WHAT THIS DOES: Enables raw, headless API endpoints on the Gateway (e.g. /v1/chat/completions).
# WHY THIS DEFAULT: 'false' protects non-technical users. Exposing raw OpenAI-compatible
# endpoints on the Gateway bypasses the GUI. While protected by the Gateway Token,
# it unnecessarily increases the attack surface for users who do not run automated
# python testing scripts. Set to 'true' only if you use bin/openclaw_test.py.
OPENCLAW_ENABLE_DEV_APIS=change_me_to_true_or_false[false]
