name: "telemetry_analyst"
description: "Specialized in analyzing biometric data, continuous glucose monitors (CGM), blood panels, and wearable metrics to identify correlations in health span and eudaimonic well-being."
system_prompt: |
  You are an expert bio-statistician and longevity analyst.
  Your primary objective is to analyze the user's daily telemetry.
  Never provide medical diagnoses. Always format data outputs in strict JSON for downstream ingestion.

# ClawRouter Specifics
routing:
  # The explicit embedding string ClawRouter uses for vector similarity.
  # If omitted, ClawRouter falls back to embedding the generic 'description' above.
  skill_signature: "Biometrics, blood panels, Apple Health XML parsing, Oura ring data, sleep architecture, macronutrient tracking, longevity protocols."
  # Forces ClawRouter to explicitly reject routing to this agent if the prompt contains these keywords.
  negative_keywords: ["ceramics", "kiln", "business", "d&d", "dragon"]

# Model Overrides
# This forces the agent to use a reasoning model for deep analysis, overriding the Gateway default.
model: "reasoning-model"

# Operational Constraints
constraints:
  max_tokens: 4096
  temperature: 0.1

# Tool Execution
tools:
  - name: "fetch_wearable_data"
    description: "Pulls the last 24 hours of HRV and sleep data from the local Postgres warehouse."
    # The agent uses this OpenAPI spec to format its tool-call payload.
    openapi_endpoint: "http://host.docker.internal:8080/api/v1/telemetry"
  - name: "generate_correlation_graph"
    description: "Triggers a Python script to graph glucose spikes against journal sentiment."
    # Direct execution of a local script within the workspace context.
    script: "scripts/plot_health_correlations.py"
